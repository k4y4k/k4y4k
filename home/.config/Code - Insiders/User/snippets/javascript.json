{
  // Place your snippets for javascript here. Each snippet is defined under a snippet name and has a prefix, body and
  // description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
  // $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the
  // same ids are connected.
  // Example:
  // "Print to console": {
  // 	"prefix": "log",
  // 	"body": [
  // 		"console.log('$1');",
  // 		"$2"
  // 	],
  // 	"description": "Log output to console"
  // }

  "styled components": {
    "prefix": "ims",
    "body": ["import styled from 'styled-components';","$0"]
  },

  "component w/ styled-components export": {
    "prefix": "rco",
    "body": [
      "const Unstyled${1:Name} = ({className, children}) => {$0}",
      "",
      "const ${1:Name} = styled(Unstyled${1:Name})``",
      "",
      "export default ${1:Name}"
    ]
  },
 
"import redux":{
  "prefix": "imc",
  "body": ["import {connect} from 'react-redux'","$0"]
},
"`connect`ed component w/ styled-components export": {
  "prefix": "crco",
  "body": [
    "const mapStateToProps = (state)=>{}",
    "",
    "const Unstyled${1:Name} = ({className, children, dispatch}) => {$0}",
    "",
    "const ${1:Name} = styled(Unstyled${1:Name})``",
    "",
    "export default connect(mapStateToProps)(${1:Name})"
  ]
},

}
